# ─── Admin Login ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@globalvillagestreet26.com
ADMIN_PASSWORD=YourSecurePassword123!

# ─── Data storage (REQUIRED — fixes "countries/admin edits don't save") ───────
# Created automatically when you connect an "Upstash for Redis" database to
# this project from the Vercel dashboard (Storage tab). Do not set manually —
# Vercel injects these for you.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── File uploads (REQUIRED — ID photos / payment screenshots) ────────────────
# Created automatically when you connect a "Blob" store to this project from
# the Vercel dashboard (Storage tab). Do not set manually.
BLOB_READ_WRITE_TOKEN=

# ─── Site URL (used for metadata) ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# ─── Google Drive (optional — for ID/payment uploads) ─────────────────────────
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=1abc...folderID

# ─── Google Sheets (optional — for registration tracking) ─────────────────────
GOOGLE_SHEETS_ID=1abc...spreadsheetID

# ─── Telegram Bot (optional — new registration notifications) ─────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-100123456789

# ─── Email (optional — approval/rejection emails via Resend) ──────────────────
RESEND_API_KEY=re_abc123...
EMAIL_FROM=noreply@globalvillagestreet26.com
